#include <bits/stdc++.h>
using namespace std;

int main() {
	int t;
	cin>>t;
	while(t--){
	    int n,k;
	     cin>>n>>k;
	      vector<int>v(n);
	    int sum=0;
	    for(int i=0;i<n;i++){
	        cin>>v[i];
	        sum+=v[i];
	    }
	    int count=0;
	    for(int i=0;i<n;i++){
	        for(int j=i+1;j<n;j++){
	            int cap=(sum-v[i]-v[j])/2;
	            cap=cap+v[i]+v[j];
	            if(cap>k){
	                count++;
	            }
	        }
	    }
	    cout<<count<<endl;
	}
	return 0;

}